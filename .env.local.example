# Sao chép thành .env.local (local) và khai báo trong Vercel (production).
# Khi để trống, app chạy bằng mock data (xem được nhưng không lưu/không thanh toán thật).

# ── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # chỉ dùng phía server (webhook, ghi danh) — KHÔNG để lộ

# ── SePay (thanh toán VietQR + webhook đối soát) ──────────
SEPAY_ACCOUNT=                      # số tài khoản ngân hàng nhận tiền
SEPAY_BANK=                         # mã ngân hàng: VCB, TCB, MB, ACB, BIDV...
SEPAY_WEBHOOK_API_KEY=              # khóa xác thực webhook (đặt trùng trong cấu hình SePay)

# ── Bunny.net (video bảo vệ) ──────────────────────────────
BUNNY_STREAM_LIBRARY_ID=
BUNNY_STREAM_API_KEY=
BUNNY_STREAM_TOKEN_KEY=          # "Token Authentication Key" của Stream library (chống tải trộm)

# ── Email (Resend) ────────────────────────────────────────
RESEND_API_KEY=                 # re_... (gửi biên lai/email; cần xác thực domain gửi)
RESEND_FROM=VIE AI EDU <no-reply@vieaiedu.vn>

# ── Analytics ─────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=              # G-XXXXXXXXXX (Google Analytics 4) — bỏ trống nếu chưa dùng

# ── Khác ──────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://vieaiedu.vn
